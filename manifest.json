{
  "manifest_version": 3,
  "name": "more-friction",
  "version": "0.1.0",
  "description": "Adds friction to attention-draining sites: a personal technological fence.",
  "permissions": ["declarativeNetRequest", "webNavigation", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "main/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["ui/content/youtube-shorts-hider.js"],
      "css": ["ui/content/youtube-shorts-hider.css"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "youtube-shorts",
        "enabled": true,
        "path": "rules/youtube-shorts.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["ui/pages/blocked/blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
